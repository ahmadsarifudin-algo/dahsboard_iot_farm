# ============================================================
# IoT Dashboard Frontend — Environment Configuration
# ============================================================
# Copy this file to .env.local and adjust for your environment:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to browser.
# ============================================================

# --- API Backend URL ---
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Docker / staging:
# NEXT_PUBLIC_API_URL=http://backend:8000/api/v1

# Production:
# NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1

# --- WebSocket URL ---
# Local development:
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Docker / staging:
# NEXT_PUBLIC_WS_URL=ws://backend:8000/ws

# Production:
# NEXT_PUBLIC_WS_URL=wss://api.your-domain.com/ws

# --- MQTT WebSocket (external broker) ---
NEXT_PUBLIC_MQTT_URL=ws://broker.chickinindonesia.com:8083/mqtt
NEXT_PUBLIC_MQTT_USERNAME=iotChickinServerNode
NEXT_PUBLIC_MQTT_PASSWORD=60zJ23n*eVCQ

# Secure alternative:
# NEXT_PUBLIC_MQTT_URL=wss://broker.chickinindonesia.com:8084/mqtt
